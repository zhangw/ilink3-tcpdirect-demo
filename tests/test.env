# iLink3 Test Suite Configuration
#
# Source this file or pass as env vars to configure test behavior.
# Usage:
#   docker run --env-file tests/test.env ... /app/tests/run_all_tests.sh
#
# Or override individual values:
#   docker run -e PERF_ROUNDS=500 -e THRESH_SEQUENCE_MS=25 ...

# ── Test selection ───────────────────────────────────────────────────────
# Set to 1 to skip a test layer
# SKIP_UNIT=0
# SKIP_INTEGRATION=0
# SKIP_PERF=0

# ── Network config ───────────────────────────────────────────────────────
SERVER_IP=10.0.0.1
CLIENT_IP=10.0.0.2
PORT=10000

# ── Integration test config ─────────────────────────────────────────────
ROUNDS=3

# ── Performance test config ──────────────────────────────────────────────
PERF_ROUNDS=100

# ── Performance thresholds (ms) ─────────────────────────────────────────
# Set to 0 to disable a threshold check.
# NOTE: In the ZF b2b emulator, recv_msg polls at POLL_TIMEOUT_NS (100ms),
# so each message round-trip takes ~100ms minimum. Set thresholds accordingly.
THRESH_NEGOTIATE_MS=500
THRESH_ESTABLISH_MS=500
THRESH_SEQUENCE_MS=500
THRESH_TOTAL_MS=120000
