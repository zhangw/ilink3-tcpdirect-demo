# Remote server profile template.
# Copy to profiles/<hostname>.env and fill in your values.
# profiles/*.env are gitignored — do not commit real credentials.

REMOTE_HOST=my-build-box          # SSH alias from ~/.ssh/config, or direct IP
REMOTE_USER=myuser                 # SSH login username
REMOTE_PATH='~/projects/ilink3-demo'  # destination path on remote
# REMOTE_SSH_KEY=~/.ssh/id_rsa    # optional: only if not using ~/.ssh/config IdentityFile
